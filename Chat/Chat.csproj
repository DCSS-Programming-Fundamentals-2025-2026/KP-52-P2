<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <DefaultItemExcludes>$(DefaultItemExcludes);Chat.Lib\**;Contracts\**</DefaultItemExcludes>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="Contracts\Contracts.csproj" />
    <ProjectReference Include="Chat.Lib\Lib.MathCore\Lib.MathCore.csproj" />
    <ProjectReference Include="Chat.Lib\Lib.Sampling\scr.csproj" />
    <ProjectReference Include="Chat.Lib\Lib.Tokenization\Lib.Tokenization.csproj" />
    <ProjectReference Include="Chat.Lib\Lib.Corpus\Lib.Corpus.csproj" />
    <ProjectReference Include="Chat.Lib\Lib.Models.TinyTransformer\Lib.Models.TinyTransformer.csproj" />
    <ProjectReference Include="Chat.Lib\Lib.Models.NGram\Lib.Models.NGram.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="Chat.Lib\**\*.cs" />
    <Compile Remove="Contracts\**\*.cs" />
  </ItemGroup>

</Project>
